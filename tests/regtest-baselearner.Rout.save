> ### check if data beyond boundary knots is permitted
> set.seed(1234)
> x <- rnorm(100)
> y <- sin(x) + rnorm(100, sd = 0.1)
> plot(x, y, xlim = c(-3, 5))
> ## should not work:
> try(mod <- mboost(y ~ bbs(x, boundary.knots = c(-1, 1))))
Error in bsplines(mf[[i]], knots = args$knots[[i]]$knots, boundary.knots = args$knots[[i]]$boundary.knots,  : 
  some 'x' values are beyond 'boundary.knots'
> try(mod <- mboost(y ~ bbs(x, cyclic = TRUE, boundary.knots = c(-1, 1))))
Error in cbs(mf[[i]], knots = args$knots[[i]]$knots, boundary.knots = args$knots[[i]]$boundary.knots,  : 
  some 'x' values are beyond 'boundary.knots'
> ## now fit models and check linear extrapolation
> mod <- mboost(y ~ bbs(x))
> tail(pr <- predict(mod, newdata = data.frame(x = seq(-3, 5, by = 0.1))))
        [,1]
[76,] -0.271
[77,] -0.317
[78,] -0.363
[79,] -0.409
[80,] -0.454
[81,] -0.500
Warning message:
In bsplines(mf[[i]], knots = args$knots[[i]]$knots, boundary.knots = args$knots[[i]]$boundary.knots,  :
  Some 'x' values are beyond 'boundary.knots'; Linear extrapolation used.
> lines(seq(-3, 5, by = 0.1), pr)
> ## now with bmono
> mod <- mboost(y ~ bmono(x))
> tail(pr2 <- predict(mod, newdata = data.frame(x = seq(-3, 5, by = 0.1))))
      [,1]
[76,] 1.15
[77,] 1.16
[78,] 1.16
[79,] 1.17
[80,] 1.17
[81,] 1.18
Warning message:
In bsplines(mf[[i]], knots = args$knots[[i]]$knots, boundary.knots = args$knots[[i]]$boundary.knots,  :
  Some 'x' values are beyond 'boundary.knots'; Linear extrapolation used.
> lines(seq(-3, 5, by = 0.1), pr2, col = "red")
> ## check same with cyclic splines
> mod <- mboost(y ~ bbs(x, cyclic = TRUE))
> try(predict(mod, newdata = data.frame(x = seq(-3, 5, by = 0.1))))
Error in cbs(mf[[i]], knots = args$knots[[i]]$knots, boundary.knots = args$knots[[i]]$boundary.knots,  : 
  some 'x' values are beyond 'boundary.knots'
