glmboost.formula(formula = y ~ x1 + x2, family = Binomial(type = "adaboost",     link = "log"))


	 Negative Binomial Likelihood -- log link 

Loss function: { 
     p <- link$linkinv(f) 
     y <- (y + 1)/2 
     -y * log(p) - (1 - y) * log(1 - p) 
 } 
 

